# Copy this file to .env and adjust if needed.
# These are committed-safe defaults matching web/scripts/seed.ts

# Base URL of the app under test. Playwright's webServer will boot the app
# on this same port, so keep these in sync with web/package.json's "dev"/"start" scripts.
BASE_URL=http://localhost:3000

# Seeded credentials (see web/scripts/seed.ts) — fixed by design, not secrets,
# this is a local demo DB seeded with bcrypt hashes of 'Password1!'
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Password1!

USER_EMAIL=user@example.com
USER_PASSWORD=Password1!

# Path to the sqlite file, used by global-setup.ts to reset state between runs.
# Relative to tests/ working directory.
DATABASE_FILE=../web/dev.db
