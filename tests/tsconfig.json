{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "paths": {
      "@pages/*": ["./src/pages/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@data/*": ["./src/data/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts", "e2e/**/*.ts", "integration/**/*.ts", "*.config.ts"],
  "exclude": ["node_modules", "dist", "playwright-report", "test-results"]
}
