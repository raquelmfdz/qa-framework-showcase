{
  "name": "playwright-qa-framework-showcase",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "tests",
    "non-functional-tests/a11y"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "prisma:migrate": "npm run prisma:migrate --workspace=web",
    "prisma:seed": "npm run prisma:seed --workspace=web",
    "test:unit": "npm run test:unit --workspace=tests",
    "test:integration": "npm run test:integration --workspace=tests",
    "test:e2e": "npm run test:e2e --workspace=tests",
    "test:a11y": "npm run test:a11y --workspace=non-functional-tests/a11y",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "fix": "eslint . --ext .ts,.tsx --fix && prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
