{
  "name": "playwright-qa-framework-showcase",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app",
    "tests",
    "a11y"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "npm run dev --workspace=app",
    "test:unit": "npm run test:unit --workspace=tests",
    "test:integration": "npm run test:integration --workspace=tests",
    "test:e2e": "npm run test:e2e --workspace=tests",
    "test:a11y": "npm run test:a11y --workspace=a11y",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
